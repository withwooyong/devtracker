generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("MEMBER") // ADMIN | MEMBER
  avatarUrl String?
  createdAt DateTime @default(now())

  reportedIssues Issue[]        @relation("Reporter")
  assignedIssues Issue[]        @relation("Assignee")
  comments       Comment[]
  deployments    Deployment[]
  projects       Project[]
  activities     Activity[]
  savedFilters   SavedFilter[]
  createdSprints Sprint[]       @relation("SprintCreator")
  notifications  Notification[]
  attachments    Attachment[]
}

model Project {
  id          String   @id @default(uuid())
  name        String
  key         String   @unique
  description String?
  createdById String
  createdAt   DateTime @default(now())

  createdBy    User          @relation(fields: [createdById], references: [id])
  issues       Issue[]
  labels       Label[]
  deployments  Deployment[]
  savedFilters SavedFilter[]
  sprints      Sprint[]
}

model Issue {
  id          String   @id @default(uuid())
  projectId   String
  issueNumber Int
  title       String
  description String?
  status      String   @default("TODO") // TODO | IN_PROGRESS | IN_REVIEW | DONE
  priority    String   @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  assigneeId  String?
  reporterId  String
  kanbanOrder Int      @default(0)
  dueDate     DateTime?
  sprintId    String?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?      @relation("Assignee", fields: [assigneeId], references: [id])
  reporter   User       @relation("Reporter", fields: [reporterId], references: [id])
  sprint     Sprint?    @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  comments    Comment[]
  labels      Label[]      @relation("IssueLabels")
  activities  Activity[]
  attachments Attachment[]

  @@unique([projectId, issueNumber])
}

model Label {
  id        String @id @default(uuid())
  projectId String
  name      String
  color     String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[] @relation("IssueLabels")

  @@unique([projectId, name])
}

model Comment {
  id        String   @id @default(uuid())
  issueId   String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])
}

model Deployment {
  id          String   @id @default(uuid())
  projectId   String
  version     String
  environment String // DEV | STAGING | PROD
  status      String   @default("PENDING") // PENDING | IN_PROGRESS | SUCCESS | FAILED | ROLLED_BACK
  description String?
  changes     String?
  deployedById String
  deployedAt  DateTime?
  createdAt   DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployedBy User    @relation(fields: [deployedById], references: [id])
}

model Activity {
  id        String   @id @default(uuid())
  issueId   String
  userId    String
  action    String   // CREATED | STATUS_CHANGED | PRIORITY_CHANGED | ASSIGNEE_CHANGED | LABEL_ADDED | LABEL_REMOVED | COMMENT_ADDED | SPRINT_CHANGED | ATTACHMENT_ADDED | ATTACHMENT_REMOVED
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])
}

model Attachment {
  id        String   @id @default(uuid())
  issueId   String
  userId    String
  filename  String
  url       String
  size      Int
  mimeType  String
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([issueId, createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // ISSUE_ASSIGNED | ISSUE_STATUS_CHANGED | ISSUE_COMMENTED | SPRINT_STARTED | SPRINT_COMPLETED
  title     String
  message   String
  link      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model Sprint {
  id          String    @id @default(uuid())
  projectId   String
  name        String
  goal        String?
  startDate   DateTime
  endDate     DateTime
  status      String    @default("PLANNED") // PLANNED | ACTIVE | COMPLETED
  createdById String
  createdAt   DateTime  @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("SprintCreator", fields: [createdById], references: [id])
  issues    Issue[]
}

model SavedFilter {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  name      String
  filters   String   // JSON: { status, priority, assigneeId, search }
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
}
